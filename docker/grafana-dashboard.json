            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 120 }
            ]
          },
          "unit": "dtdurations"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
