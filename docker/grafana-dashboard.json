    {
      "id": 5,
      "title": "Kill Switch Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bot_kill_switch_state",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "SAFE" } }, "type": "value" },
            { "options": { "1": { "color": "yellow", "index": 1, "text": "ARMED" } }, "type": "value" },
            { "options": { "2": { "color": "red", "index": 2, "text": "TRIGGERED" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "title": "Heartbeat Age",
