      "title": "Performance",
      "type": "row"
    },
    {
      "id": 8,
      "title": "Win Rate %",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bot_win_rate_pct",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      }
    },
    {
      "id": 9,
      "title": "Total Trades",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (side) (increase(bot_trades_total[24h]))",
          "legendFormat": "{{side}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 10,
      "title": "Signal Strength",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bot_signal_strength",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 11,
      "panels": [],
      "title": "Bot Health",
      "type": "row"
    },
    {
      "id": 12,
      "title": "Open Positions",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bot_open_positions",
          "format": "table",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "bot_id": "Bot",
              "symbol": "Symbol",
              "Value": "Positions"
            }
          }
        }
      ]
    },
    {
      "id": 13,
      "title": "Reconciliation Drift",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bot_reconciliation_drift_usd",
          "legendFormat": "{{bot_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "line" }
          },
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 14,
      "panels": [],
      "title": "Alerts",
      "type": "row"
    },
    {
      "id": 15,
      "title": "Alert History",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (bot_id, severity) (increase(bot_alerts_total[24h]))",
          "format": "table",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "critical": { "color": "red", "index": 0 } }, "type": "value" },
                  { "options": { "warning": { "color": "yellow", "index": 1 } }, "type": "value" },
                  { "options": { "info": { "color": "blue", "index": 2 } }, "type": "value" }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "bot_id": "Bot",
              "severity": "Severity",
              "Value": "Alert Count (24h)"
            }
          }
        }
      ]
    }
