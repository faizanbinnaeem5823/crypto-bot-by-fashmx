# =============================================================================
# CRYPTO BOT - Environment Configuration (.env.example)
# =============================================================================
# This file documents EVERY secret and configuration variable.
# Copy to .env and fill in real values. NEVER commit .env to git.
# Use sops + age for encrypted secrets in production.
# =============================================================================

# ==========================================
# EXCHANGE API KEYS (Binance)
# ==========================================
# Bot A - Primary (15m-4h conservative timeframe)
# Restricted to SPOT trading only. Withdrawal permission: DISABLED.
BINANCE_BOT_A_API_KEY=your_bot_a_api_key_here
BINANCE_BOT_A_API_SECRET=your_bot_a_api_secret_here

# Bot B - Experimental (5m-15m timeframe)
# Smaller position sizing, higher signal frequency. Withdrawal permission: DISABLED.
BINANCE_BOT_B_API_KEY=your_bot_b_api_key_here
BINANCE_BOT_B_API_SECRET=your_bot_b_api_secret_here

# Use testnet for paper trading (binance-testnet)
BINANCE_TESTNET=true

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
POSTGRES_USER=cryptobot
POSTGRES_PASSWORD=generate_strong_password_here_min_32_chars
POSTGRES_DB=cryptobot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=generate_strong_password_here

# ==========================================
# MONITORING (Grafana + Prometheus)
# ==========================================
GF_SECURITY_ADMIN_PASSWORD=generate_grafana_admin_password
PROMETHEUS_RETENTION=30d

# ==========================================
# ALERTS (Slack + Discord + Email)
# ==========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=your_alert_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_specific_password
ALERT_EMAIL_TO=your_phone_email@example.com

# ==========================================
# BOT CONFIGURATION
# ==========================================
BOT_A_INITIAL_CAPITAL_USD=500
BOT_B_INITIAL_CAPITAL_USD=500
RISK_PROFILE=conservative
ENVIRONMENT=paper

# ==========================================
# SECURITY
# ==========================================
# IP addresses allowed for API access (comma-separated)
WHITELISTED_IPS=your_vps_ip,your_home_ip
# Encrypted secrets key file path
SOPS_AGE_KEY_FILE=secrets/age.key
